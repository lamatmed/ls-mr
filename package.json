{
    "name": "stock-local",
    "version": "0.1.0",
    "private": true,
    "main": "electron/main.cjs",
    "type": "module",
    "scripts": {
        "dev": "next dev --turbopack",
        "build": "next build",
        "start": "next start",
        "lint": "next lint",
        "desktop": "concurrently \"npm run dev\" \"wait-on http://localhost:3000 && electron .\"",
        "dist": "npm run build && npx electron-builder",
        "postinstall": "prisma generate"
    },
    "dependencies": {
        "@ducanh2912/next-pwa": "^10.2.9",
        "@prisma/client": "^6.6.0",
        "arabic-persian-reshaper": "^1.0.1",
        "bcrypt": "^5.1.1",
        "bcryptjs": "^3.0.2",
        "bidi-js": "^1.0.3",
        "canvg": "^4.0.3",
        "chart.js": "^4.4.8",
        "cookies-next": "^5.1.0",
        "framer-motion": "^12.6.3",
        "geist": "^1.3.1",
        "jsonwebtoken": "^9.0.2",
        "jspdf": "^3.0.1",
        "jspdf-autotable": "^5.0.2",
        "lightningcss": "^1.29.3",
        "next": "^15.2.4",
        "openai": "^4.95.0",
        "react": "^19.1.0",
        "react-dom": "^19.1.0",
        "react-icons": "^5.5.0",
        "react-toastify": "^11.0.5",
        "styled-components": "^6.1.16",
        "sweetalert2": "^11.17.2"
    },
    "devDependencies": {
        "@eslint/eslintrc": "^3.3.1",
        "@tailwindcss/postcss": "^4.0.17",
        "@types/bcrypt": "^5.0.2",
        "@types/estree": "^1.0.7",
        "@types/json-schema": "^7.0.15",
        "@types/jsonwebtoken": "^9.0.9",
        "@types/ms": "^2.1.0",
        "@types/node": "^22.13.14",
        "@types/raf": "^3.4.3",
        "@types/react": "^19.0.12",
        "@types/react-dom": "^19.0.4",
        "autoprefixer": "^10.4.21",
        "concurrently": "^9.2.1",
        "electron": "^40.2.1",
        "electron-builder": "^25.1.8",
        "electron-is-dev": "^3.0.1",
        "eslint": "^9.23.0",
        "eslint-config-next": "15.2.2",
        "postcss": "^8.5.3",
        "prisma": "^6.5.0",
        "tailwindcss": "^3.4.17",
        "typescript": "^5.8.2",
        "wait-on": "^9.0.3"
    },
    "build": {
        "appId": "com.stocklocal.app",
        "productName": "StockLocal",
        "copyright": "Copyright © 2026 StockLocal",
        "directories": {
            "output": "dist_desktop"
        },
        "files": [
            "**/*",
            "!dist_desktop",
            "!node_modules",
            "node_modules/**/*"
        ],
        "win": {
            "target": "nsis",
            "icon": "public/lok.jpg"
        },
        "nsis": {
            "oneClick": false,
            "allowToChangeInstallationDirectory": true,
            "createDesktopShortcut": true
        }
    }
}
