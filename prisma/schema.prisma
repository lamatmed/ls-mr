// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id       String @id @default(uuid())
  nom      String @unique
  password String
  admin    Boolean @default(false)
  isBlocked Boolean @default(false)
  transactions Transaction[]
}

model Category {
  id        String    @id @default(uuid())
  name      String    @unique
  products  Product[]
  createdAt DateTime  @default(now())
}

model Product {
  id             String   @id @default(uuid())
  code           Int      @unique
  name           String
  quantity       Int      @default(0)
  price_v        Float
  price_a        Float
  expirationDate DateTime
  createdAt      DateTime @default(now())
  codeBar        String?  @unique
  categoryId     String?
  category       Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  fournisseurId  String?
  fournisseur    Fournisseur? @relation(fields: [fournisseurId], references: [id], onDelete: SetNull)
  sales          Sale[]
  transactions   Transaction[]
  deleted        Boolean  @default(false)
}

model Sale {
  id            String   @id @default(uuid())
  product       Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  productId     String?
  quantity      Int
  totalPrice    Float
  purchasePrice Float
  invoiceId     String?  @map("invoiceId")
  invoice       Invoice? @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
  createdAt     DateTime @default(now())
}

model Invoice {
  id            String   @id @default(uuid())
  totalAmount   Float
  purchaseTotal Float
  createdAt     DateTime @default(now())

  sales         Sale[]
  type          String   @default("CASH") // "CASH" or "DEBT"
  clientId      String?
  client        Client?  @relation(fields: [clientId], references: [id], onDelete: SetNull)
  
  debtId        String?
  debt          Debt?    @relation(fields: [debtId], references: [id], onDelete: SetNull)
}

model Client {
  id       String    @id @default(uuid())
  nom      String
  tel      String    @unique
  nif      String?   @unique
  solde    Float     @default(0)
  invoices Invoice[]
  debts    Debt[]
}

model Transaction {
  id        String   @id @default(uuid())
  product   Product  @relation(fields: [productId], references: [id])
  productId String
  quantity  Int
  type      String   // "ajout", "retrait", etc.
  date      DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id])
  userId    String?
}

model Company {
  id        String   @id @default("1")
  name      String
  address   String
  contact   String
  nif       String?
  currency  String   @default("MRU")
  logo      String?
  updatedAt DateTime @updatedAt
}

model Debt {
  id          String   @id @default(uuid())
  clientId    String   @unique
  client      Client   @relation(fields: [clientId], references: [id])
  invoices    Invoice[]
  
  totalAmount Float
  amountPaid  Float    @default(0)
  remaining   Float
  status      String   @default("UNPAID") // "UNPAID", "PARTIAL", "PAID"
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Expense {
  id          String   @id @default(uuid())
  type        String   // "SALAIRE", "LOCATION", "AUTRES"
  description String?
  amount      Float
  createdAt   DateTime @default(now())
}

model Fournisseur {
  id        String    @id @default(uuid())
  name      String    @unique
  contact   String?
  products  Product[]
  createdAt DateTime  @default(now())
}

